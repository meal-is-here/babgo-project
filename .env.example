# Database 설정
DB_URL=jdbc:postgresql://localhost:5432/babgo
DB_USERNAME=postgres
DB_PASSWORD=your-database-password

# Redis 설정 (Refresh Token 저장소)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 설정
# JWT_SECRET: 최소 256비트(32바이트) 이상의 비밀키 필요
# 예시: openssl rand -base64 32 명령어로 생성 가능
JWT_SECRET=your-super-secret-key-minimum-256-bits-required-here-please-change-this

# JWT 만료 시간 (밀리초)
# Access Token: 30분 (1800000ms)
JWT_ACCESS_TOKEN_EXPIRATION=1800000

# Refresh Token: 7일 (604800000ms)
JWT_REFRESH_TOKEN_EXPIRATION=604800000