# ==========================================
# 데이터베이스 설정 (Local 개발 환경)
# ==========================================
DB_URL=jdbc:postgresql://localhost:5432/babgo
DB_USERNAME=
DB_PASSWORD=

# ==========================================
# JWT 설정
# ==========================================
# 보안 tip: Secret Key는 최소 256bit (32자 이상) 권장
# 실제 운영에서는 랜덤하고 복잡한 문자열 사용 (예: openssl rand -base64 32)
JWT_SECRET=

# Access Token 만료 시간 (밀리초) - 기본 15분
JWT_ACCESS_TOKEN_EXPIRATION=900000

# Refresh Token 만료 시간 (밀리초) - 기본 1일
JWT_REFRESH_TOKEN_EXPIRATION=86400000

# ==========================================
# Redis 설정 (Refresh Token 저장용)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Redis TTL은 JWT Refresh Token 만료 시간과 동일하게 설정

# ==========================================
# AI API 설정 (Google Gemini)
# ==========================================
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# ==========================================
# FastAPI 설정 (추천 및 리뷰 분석 서비스)
# ==========================================
RECOMMENDATION_FASTAPI_URL=http://localhost:8000
REVIEW_ANALYSIS_FASTAPI_URL=http://localhost:8001

# ==========================================
# AWS 설정 (추후 클라우드 배포 시 사용)
# ==========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=

# ==========================================
# FastAPI
# ==========================================
RECOMMENDATION_FASTAPI_URL=http://localhost:8000
REVIEW_ANALYSIS_FASTAPI_URL=http://localhost:8000

# ==========================================
# Google AI
# ==========================================
GOOGLE_AI_API_KEY=dummy